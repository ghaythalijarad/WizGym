generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GymApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum PhoneOtpStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum TrainerHireStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum GymAudience {
  MEN_ONLY
  WOMEN_ONLY
  MIXED
}

enum AccountRole {
  ADMIN
  OWNER
  TRAINER
  USER
}

model GymApplication {
  id          String            @id
  gymName     String
  ownerName   String
  ownerUserId String
  city        String
  requestedAt DateTime
  status      GymApprovalStatus @default(PENDING)
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  gym          Gym?
  subscription PlatformSubscription?
}

model Gym {
  id            String            @id
  applicationId String?           @unique
  application   GymApplication?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  name          String
  city          String
  ownerUserId   String
  ownerName     String
  description   String?
  coverImageUrl String?
  audience      GymAudience       @default(MIXED)
  amenities     String[]          @default([])
  status        GymApprovalStatus @default(APPROVED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  memberships    GymMembership[]
  trainers       GymTrainerMembership[]
  facilities     GymFacility[]
  products       GymProduct[]
  ratings        GymRating[]
  trainerRatings TrainerRating[]
  trainerHires   TrainerHire[]

  @@index([status, city])
  @@index([ownerUserId])
}

model GymMembership {
  id       String   @id @default(cuid())
  gymId    String
  userId   String
  joinedAt DateTime @default(now())

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
  @@index([userId])
}

model GymTrainerMembership {
  id        String   @id @default(cuid())
  gymId     String
  trainerId String
  joinedAt  DateTime @default(now())
  active    Boolean  @default(true)

  gym     Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  hires   TrainerHire[]
  ratings TrainerRating[]

  @@unique([gymId, trainerId])
  @@index([trainerId, active])
}

model TrainerHire {
  id        String            @id @default(cuid())
  gymId     String
  trainerId String
  userId    String
  status    TrainerHireStatus @default(ACTIVE)
  hiredAt   DateTime          @default(now())
  endedAt   DateTime?

  gym               Gym                  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainerMembership GymTrainerMembership @relation(fields: [gymId, trainerId], references: [gymId, trainerId], onDelete: Cascade)

  @@unique([gymId, trainerId, userId])
  @@index([userId, status])
}

model GymRating {
  id        String   @id @default(cuid())
  gymId     String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
  @@index([gymId])
}

model TrainerRating {
  id        String   @id @default(cuid())
  gymId     String
  trainerId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym               Gym                  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainerMembership GymTrainerMembership @relation(fields: [gymId, trainerId], references: [gymId, trainerId], onDelete: Cascade)

  @@unique([gymId, trainerId, userId])
  @@index([trainerId])
}

model GymFacility {
  id          String   @id @default(cuid())
  gymId       String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model GymProduct {
  id          String   @id @default(cuid())
  gymId       String
  title       String
  description String?
  imageUrl    String?
  price       Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, isActive])
}

model PlatformSubscription {
  id              String             @id
  gymId           String             @unique
  gym             GymApplication     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  gymName         String
  planName        String
  membersLimit    Int
  monthlyPrice    Int
  nextBillingDate DateTime
  status          SubscriptionStatus @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
}

model PhoneVerificationSession {
  id          String         @id @default(cuid())
  phoneNumber String
  codeHash    String
  codeSalt    String
  smsId       String?
  provider    String?
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int            @default(0)
  maxAttempts Int
  status      PhoneOtpStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([phoneNumber, status, createdAt])
}

model UserAccount {
  id          String      @id @default(cuid())
  phoneNumber String      @unique
  displayName String
  role        AccountRole
  lastLoginAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
