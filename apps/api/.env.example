# WizGym API Environment Variables
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# DynamoDB Tables
DYNAMODB_USERS_TABLE=wizgym-users
DYNAMODB_GYMS_TABLE=wizgym-gyms
DYNAMODB_MEMBERSHIPS_TABLE=wizgym-memberships
DYNAMODB_CLASSES_TABLE=wizgym-classes
DYNAMODB_BOOKINGS_TABLE=wizgym-bookings

# Cognito
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id

# API Configuration
API_STAGE=dev
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
